name: StoreSales-DeepLearning

conda_env: conda.yaml

entry_points:
  main:
    parameters:
      epochs:
        type: int
        default: 30
      batch_size:
        type: int
        default: 2048
      learning_rate:
        type: float
        default: 0.001
      dropout_rate:
        type: float
        default: 0.3
      units_layer1:
        type: int
        default: 256
      units_layer2:
        type: int
        default: 128
      units_layer3:
        type: int
        default: 64
      test_size:
        type: float
        default: 0.2
    command: "python modelling.py --epochs {epochs} --batch_size {batch_size} --learning_rate {learning_rate} --dropout_rate {dropout_rate} --units_layer1 {units_layer1} --units_layer2 {units_layer2} --units_layer3 {units_layer3} --test_size {test_size}"